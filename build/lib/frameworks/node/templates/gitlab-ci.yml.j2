image: node:{{ node_version }}

stages:
  - install
  - lint
  - test
  - build
  - deploy

cache:
  paths:
    - node_modules/
    {% if package_manager == 'yarn' %}
    - .yarn
    {% elif package_manager == 'pnpm' %}
    - .pnpm-store
    {% endif %}

variables:
  NODE_ENV: "production"

install:
  stage: install
  script:
    {% if package_manager == 'npm' %}
    - npm ci
    {% elif package_manager == 'yarn' %}
    - yarn install --frozen-lockfile
    {% elif package_manager == 'pnpm' %}
    - pnpm install --frozen-lockfile
    {% endif %}
  artifacts:
    paths:
      - node_modules/
    expire_in: 1 hour

lint:
  stage: lint
  script:
    - {{ package_manager }} run lint || echo "No lint script found"
  dependencies:
    - install

test:
  stage: test
  script:
    - {{ package_manager }} test
  coverage: '/All files[^|]*\|[^|]*\s+([\d\.]+)/'
  dependencies:
    - install

build:
  stage: build
  script:
    - {{ package_manager }} run build || echo "No build script found"
  artifacts:
    paths:
      - dist/
      - build/
    expire_in: 1 week
  dependencies:
    - install

docker:
  stage: deploy
  image: docker:latest
  services:
    - docker:dind
  script:
    - docker build -t $CI_REGISTRY_IMAGE:$CI_COMMIT_SHORT_SHA .
    - docker build -t $CI_REGISTRY_IMAGE:latest .
  only:
    - main
    - master
