name: CI/CD Pipeline

on:
  push:
    branches: [ main, master, develop ]
  pull_request:
    branches: [ main, master, develop ]

jobs:
  test:
    runs-on: ubuntu-latest

    strategy:
      matrix:
        java-version: [{{ java_version }}]

    steps:
    - name: Checkout code
      uses: actions/checkout@v3

    - name: Set up JDK {% raw %}${{ matrix.java-version }}{% endraw %}
      uses: actions/setup-java@v3
      with:
        java-version: {% raw %}${{ matrix.java-version }}{% endraw %}
        distribution: 'temurin'
        cache: 'gradle'

    - name: Grant execute permission for gradlew
      run: chmod +x gradlew

    - name: Build with Gradle
      run: ./gradlew clean build -x test

    - name: Run tests
      run: ./gradlew test

    - name: Generate test report
      uses: dorny/test-reporter@v1
      if: success() || failure()
      with:
        name: Gradle Tests
        path: build/test-results/test/TEST-*.xml
        reporter: java-junit

    - name: Upload coverage to Codecov
      uses: codecov/codecov-action@v3
      if: success()
      with:
        files: ./build/reports/jacoco/test/jacocoTestReport.xml
        flags: unittests
        name: codecov-umbrella

    - name: Package application
      run: ./gradlew {% if packaging == 'jar' %}bootJar{% else %}build{% endif %} -x test

    - name: Upload artifacts
      uses: actions/upload-artifact@v3
      with:
        name: gradle-artifacts
        path: build/libs/*.jar

  docker:
    runs-on: ubuntu-latest
    needs: test
    if: {% raw %}github.event_name == 'push' && (github.ref == 'refs/heads/main' || github.ref == 'refs/heads/master'){% endraw %}

    steps:
    - name: Checkout code
      uses: actions/checkout@v3

    - name: Set up Docker Buildx
      uses: docker/setup-buildx-action@v2

    - name: Build Docker image
      uses: docker/build-push-action@v4
      with:
        context: .
        push: false
        tags: {{ project_name }}:latest
